{
  "name": "zaya-group-calling-system",
  "version": "2.0.15",
  "description": "Zaya Group Calling System - Full Stack CRM",
  "main": "electron/main.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "client": "cd client && npm start",
    "dev:full": "concurrently \"npm run dev\" \"npm run client\"",
    "install:all": "npm install && cd client && npm install",
    "build": "npm --prefix client run build",
    "build:web": "npm --prefix client run build",
    "vercel-build": "npm run build:web",
    "start:prod": "npm run build:web && cross-env NODE_ENV=production node server.js",
    "desktop:start": "electron .",
    "desktop:dev": "concurrently \"npm run dev\" \"npm run client\" \"wait-on tcp:3000 tcp:5000 && electron .\"",
    "desktop:dist": "npm run build:web && electron-builder --win nsis --mac dmg zip",
    "desktop:dist:win": "npm run build:web && electron-builder --win nsis",
    "desktop:dist:mac": "npm run build:web && electron-builder --mac dmg zip",
    "desktop:pack": "npm run build:web && electron-builder --dir --win --mac",
    "desktop:pack:win": "npm run build:web && electron-builder --dir --win",
    "desktop:pack:mac": "npm run build:web && electron-builder --dir --mac"
  },
  "dependencies": {
    "better-sqlite3": "^12.4.1",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "electron-updater": "^6.8.3",
    "express": "^4.18.2",
    "helmet": "^7.1.0",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "@vercel/blob": "^2.3.1",
    "pg": "^8.14.1",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "electron": "^35.0.2",
    "electron-builder": "^26.0.12",
    "nodemon": "^3.0.2",
    "wait-on": "^8.0.3"
  },
  "build": {
    "appId": "com.zayagroup.callingsystem",
    "productName": "Zaya Calling System",
    "artifactName": "Zaya-Calling-System-Setup-${version}.${ext}",
    "asar": true,
    "publish": [
      {
        "provider": "github",
        "owner": "Wasley-Dev",
        "repo": "zaya-calling-system-v2",
        "releaseType": "release"
      }
    ],
    "asarUnpack": [
      "node_modules/better-sqlite3/**/*"
    ],
    "files": [
      "api/**/*",
      "client/build/**/*",
      "data/**/*",
      "db/**/*",
      "electron/**/*",
      "package.json",
      "paths.js",
      "routes/**/*",
      "server.js"
    ],
    "extraMetadata": {
      "main": "electron/main.js"
    },
    "mac": {
      "icon": "build/icon.png",
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.business"
    },
    "win": {
      "icon": "build/icon.ico",
      "signAndEditExecutable": false,
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico"
    }
  }
}
